<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.org.spring_board_project.mapper.TodoMapper">

    <select id="getTime" resultType="string">
        select now()
    </select>

    <select id="insert">
        insert into tbl_todo(title, dueDate, writer) values ( #{title}, #{dueDate}, #{writer})
    </select>

    <select id="selectAll"
            resultType="com.org.spring_board_project.domain.TodoVO">
        select * from tbl_todo order by tno asc;
    </select>

    <select id="selectOne"
            resultType="com.org.spring_board_project.domain.TodoVO">
        select * from tbl_todo where tno = #{tno}
    </select>

    <delete id="delete">
        delete from tbl_todo where tno = #{tno}
    </delete>

    <update id="update">
        update tbl_todo set title = #{title}, dueDate = #{dueDate}, finished = #{finished} where tno = #{tno}
    </update>
</mapper>